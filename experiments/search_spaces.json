                "constant_liar": false
            },
            "pruner": {
                "name": "hyperband",
                "min_resource": 15,
                "reduction_factor": 3,
                "bootstrap_count": 4
            },
            "max_epochs": 90,
            "trials": 16,
            "parameters": {
                "lr": {"type": "categorical", "choices": [0.0004, 0.001, 0.003, 0.004, 0.005]},
                "weight_decay": {
                    "type": "categorical",
                    "choices": [0.0, 0.00000003, 0.00001, 0.0001]
                },
                "batch_size": {
                    "type": "categorical",
                    "choices": [32768, 16384, 8192, 4096, 2048, 1024, 512, 256]
                },
                "lr_scheduler": {"type": "categorical", "choices": ["none", "plateau"]},
                "lr_scheduler_factor": {"type": "categorical", "choices": [0.7, 0.8]},
                "interest_gnn_layers": {"type": "int", "low": 1, "high": 3},
                "conformity_gnn_layers": {"type": "int", "low": 2, "high": 3},
                "num_neighbors": {
                    "type": "fanout",
                    "choices_by_depth": {
                        "2": [[4, 2], [5, 3], [8, 4], [16, 8]],
