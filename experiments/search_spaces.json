{
    "search_spaces": {
        "ucagnn-core-optimization": {
            "description": "Small dataset-local Optuna screen for U-CaGNN. Without --dataset, the runner creates one independent study per core thesis dataset, so --trials N means target N fresh informative finished trials per dataset: COMPLETE plus real PRUNED, excluding FAIL/RUNNING, historically imported rows, and duplicate-skip prunes. The base grid is only a fallback. The parameters_by_dataset overrides are the active research grid. AmazonBook, MovieLens, and KuaiRec are already bounded by completed and real-pruned local evidence; KuaiRand uses a coarse low/medium/high regime screen because it still has no fresh local trials and should not inherit a narrow basin from imported global rows. The core search uses automatic largest-feasible batch-size probing from a descending throughput-oriented candidate ladder instead of sampling batch_size as a model-selection parameter; the selected batch size remains logged as runtime metadata. This pass tunes only active causal branch-supervision weights and a few schedule controls because thesis time is now better spent on formal reruns, diagnostics, and writing than broad hyperparameter exploration. Four-hop GNN depth remains excluded: current evidence does not justify extra over-smoothing and compute risk for the thesis budget.",
            "base_profile": "core-ucagnn-mainline",
            "datasets": ["amazonbook", "movielens1m", "kuairec_v2", "kuairand1k"],
            "config_overrides": {
                "use_early_stopping": true,
                "patience": 8,
                "auto_batch_size": true,
                "batch_size_candidates": [32768, 16384, 8192, 4096, 2048, 1024, 512, 256]
            },
            "objective": {
                "metric": "ValidationOnlineCRRU@20_40",
                "split": "val",
                "direction": "maximize"
            },
            "sampler": {
