        "edgrec-core-optimization": {
            "description": "Small dataset-local Optuna screen for compact EDGRec search-prior candidates. Without --dataset, the runner creates one independent study per listed dataset, so --trials N means target N fresh informative finished trials for the current search_space_revision per dataset: COMPLETE plus real PRUNED, excluding FAIL/RUNNING, historically imported rows, duplicate-skip prunes, and other revision hashes. For the current causal-stability pass, start with --dataset movielens1m and --dataset kuairec_v2 before promoting a configuration to expensive datasets. KuaiRand remains a randomized-exposure stress diagnostic. AmazonBook is present only as a compact exception check in this shared space; use amazonbook-edgrec-candidate-search for the dataset-specific compact-vs-deep_features comparison and keep LightGCN-paper accuracy baseline framing. The core search uses automatic largest-feasible batch-size probing from a descending throughput ladder as runtime metadata, not as a sampled model-selection parameter. This pass tunes the effective DICE branch-loss scale, negative count, score-mix floor, branch-supervision weights, and context shortcuts while keeping side features, IPW, contrastive, and DirectAU off unless a separate explicit profile enables them. hard_negative_ratio is intentionally excluded because DICE sampling owns the high/low-popularity negative route. Four-hop GNN depth remains excluded: current evidence does not justify extra over-smoothing and compute risk for the thesis budget.",
            "base_profile": "edgrec-compact-search-prior",
            "datasets": ["amazonbook", "movielens1m", "kuairec_v2", "kuairand1k"],
            "config_overrides": {
                "use_early_stopping": true,
                "patience": 8,
                "auto_batch_size": true,
                "batch_size_candidates": [1048576, 524288, 262144, 131072, 65536, 32768, 16384, 8192, 4096, 2048, 1024, 512, 256],
                "use_popularity_emb": false
            },
            "objective": {
                "metric": "ValidationOnlineCRRU@20_40",
                "split": "val",
                "direction": "maximize"
            },
            "sampler": {
                "name": "tpe",
                "seed": 42,
                "n_startup_trials": 4,
                "multivariate": false,
                "group": false,
                "constant_liar": false
            },
            "pruner": {
                "name": "hyperband",
                "min_resource": 6,
                "reduction_factor": 3,
                "bootstrap_count": 1
            },
            "max_epochs": 60,
            "trials": 8,
            "parameters": {
                "lr": {
                    "type": "grid_float",
                    "segments": [
                        {"low": 0.0002, "high": 0.0008, "step": 0.0001},
                        {"low": 0.001, "high": 0.005, "step": 0.001},
                        {"low": 0.007, "high": 0.01, "step": 0.001}
                    ]
                },
                "weight_decay": {
                    "type": "categorical",
                    "choices": [
                        0.0,
                        0.00000001,
                        0.00000003,
                        0.0000001,
                        0.0000003,
                        0.000001,
                        0.000003,
                        0.00001,
                        0.00003,
                        0.0001,
                        0.0003
                    ]
                },
                "lr_scheduler": {"type": "categorical", "choices": ["none", "cosine", "plateau"]},
                "lr_scheduler_factor": {"type": "grid_float", "low": 0.4, "high": 0.8, "step": 0.1},
                "grad_clip_norm": {"type": "categorical", "choices": [0.5, 1.0, 2.0, 3.0, 5.0]},
                "embedding_optimizer": {
                    "type": "categorical",
                    "choices": ["adamw", "sgd", "sparseadam"]
                },
                "graph_profile": {
                    "type": "categorical",
                    "choices": ["shallow_i1_c1", "lite_i1_c2", "balanced_i2_c2"]
                },
                "dropout": {"type": "grid_float", "low": 0.0, "high": 0.3, "step": 0.05},
                "train_edge_keep_prob": {"type": "categorical", "choices": [1.0, 0.8, 0.6, 0.4]},
                "n_negatives": {"type": "categorical", "choices": [1, 2, 3, 4]},
                "dice_mask_reduction": {
                    "type": "categorical",
                    "choices": ["batch_mean", "active_mean"]
                },
