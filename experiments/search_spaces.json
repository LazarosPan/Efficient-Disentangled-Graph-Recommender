{
    "search_spaces": {
        "ucagnn-core-optimization": {
            "description": "Canonical discrete Optuna screen for U-CaGNN. Without --dataset, each trial evaluates all core thesis datasets and averages the objective. With --dataset, --trials N means N independent trials for that dataset. Promote selected winners manually into formal profiles before test reporting.",
            "base_profile": "core-ucagnn-mainline",
            "datasets": ["amazonbook", "movielens1m", "kuairec_v2", "kuairand1k"],
            "objective": {
                "metric": "ValidationOnlineCRRU@20_40",
                "split": "val",
                "direction": "maximize"
            },
            "max_epochs": 80,
            "trials": 12,
            "parameters": {
                "lr": {
                    "type": "grid_float",
                    "segments": [
                        {"low": 0.0001, "high": 0.001, "step": 0.0001},
                        {"low": 0.0015, "high": 0.005, "step": 0.0005},
                        {"low": 0.0075, "high": 0.01, "step": 0.0025}
                    ]
                },
                "weight_decay": {
                    "type": "categorical",
                    "choices": [
                        0.0,
                        0.00000001,
                        0.00000003,
                        0.0000001,
                        0.0000003,
                        0.000001,
                        0.000003,
                        0.00001,
                        0.00003,
                        0.0001,
                        0.0003,
                        0.001
                    ]
                },
                "lr_scheduler": {"type": "categorical", "choices": ["none", "cosine", "plateau"]},
                "lr_scheduler_factor": {"type": "grid_float", "low": 0.3, "high": 0.8, "step": 0.1},
                "grad_clip_norm": {"type": "grid_float", "low": 0.5, "high": 5.0, "step": 0.5},
                "interest_gnn_layers": {"type": "int", "low": 1, "high": 2},
                "conformity_gnn_layers": {"type": "int", "low": 1, "high": 2},
                "num_neighbors": {
                    "type": "fanout",
                    "choices_by_depth": {
                        "1": [[8], [12], [16]],
                        "2": [[4, 2], [6, 3], [8, 4], [10, 5], [16, 8]]
                    }
                },
                "dropout": {"type": "grid_float", "low": 0.0, "high": 0.3, "step": 0.05},
                "score_mix_min_weight": {
                    "type": "grid_float",
                    "low": 0.0,
                    "high": 0.1,
                    "step": 0.01
                },
                "loss_weight_independence": {
                    "type": "grid_float",
                    "low": 0.0,
                    "high": 0.02,
                    "step": 0.0025
                },
                "loss_weight_contrastive": {
                    "type": "grid_float",
                    "low": 0.0,
                    "high": 0.05,
                    "step": 0.005
                },
                "loss_weight_popularity": {
                    "type": "grid_float",
                    "low": 0.0,
                    "high": 0.05,
                    "step": 0.005
                },
                "hard_negative_ratio": {
                    "type": "grid_float",
                    "low": 0.0,
                    "high": 0.35,
                    "step": 0.05
                },
                "dice_sampler_margin": {
                    "type": "grid_float",
                    "low": 10.0,
                    "high": 80.0,
                    "step": 10.0
                }
            }
        }
    }
}
