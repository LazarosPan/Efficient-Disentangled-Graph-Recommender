  "recipes": {
    "ucagnn": {
      "description": "UCaGNN with mini-batch training on the default observed train-interaction graph.",
      "preset": "ucagnn"
    },
    "lightgcn": {
      "description": "Scalable sampled-neighborhood LightGCN approximation with mini-batch training on the default observed train-interaction graph.",
      "preset": "lightgcn"
    },
    "lightgcn_paper": {
      "description": "Paper-faithful LightGCN adapter with full-graph propagation, observed graph only, and no dropout.",
      "preset": "lightgcn_paper"
    },
    "dice_like": {
      "description": "Legacy DICE-like ablation with mini-batch training; not the official DICE paper baseline.",
      "preset": "dice_like"
    },
    "dice_like_ablation": {
      "description": "Explicit name for the legacy DICE-like ablation; use dice_paper for the paper baseline.",
      "preset": "dice_like"
    },
    "dice_paper": {
      "description": "Paper-faithful GCN-DICE adapter with full-graph self-looped LightGCN propagation, DICE negative sampling, and DICE branch losses.",
      "preset": "dice_paper"
    }
  }
